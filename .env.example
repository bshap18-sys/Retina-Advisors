# Stripe test-mode restricted API key. Used by the Stripe MCP server
# configured in .mcp.json. Generate at:
#   https://dashboard.stripe.com/test/apikeys
# Use a RESTRICTED key (prefix rk_test_) with read-only scope on
# Disputes, Charges, Customers.
#
# Copy this file to .env and replace the placeholder.
# .env is gitignored and blocked by the PreToolUse hook.
STRIPE_API_KEY=rk_test_placeholder
